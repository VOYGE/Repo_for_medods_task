{
  "openapi": "3.0.3",
  "info": {
    "title": "Task Service API",
    "version": "1.1.0",
    "description": "Tasks API with optional recurrence schedules. Dates are interpreted in UTC (calendar-day semantics)."
  },
  "servers": [
    {
      "url": "http://localhost:8080"
    }
  ],
  "tags": [
    {
      "name": "Tasks",
      "description": "Operations with tasks"
    }
  ],
  "paths": {
    "/api/v1/tasks": {
      "get": {
        "tags": ["Tasks"],
        "summary": "List tasks",
        "parameters": [
          {
            "name": "include_templates",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            },
            "description": "Include recurrence templates (`is_template=true`). By default templates are hidden."
          },
          {
            "name": "occurrence_from",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-04-01"
            },
            "description": "UTC date inclusive lower bound for `occurrence_date`. Undated standalone tasks remain visible regardless."
          },
          {
            "name": "occurrence_to",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2026-04-30"
            },
            "description": "UTC date inclusive upper bound for `occurrence_date`."
          }
        ],
        "responses": {
          "200": {
            "description": "Task list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Task" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "post": {
        "tags": ["Tasks"],
        "summary": "Create task (optionally a recurrence template)",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateTaskRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created task",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      }
    },
    "/api/v1/tasks/{id}": {
      "get": {
        "tags": ["Tasks"],
        "summary": "Get task by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "responses": {
          "200": {
            "description": "Task",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "put": {
        "tags": ["Tasks"],
        "summary": "Update task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/UpdateTaskRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated task",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Task" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "tags": ["Tasks"],
        "summary": "Delete task",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 }
          }
        ],
        "responses": {
          "204": { "description": "Deleted" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
    "/api/v1/tasks/{id}/materialize": {
      "post": {
        "tags": ["Tasks"],
        "summary": "Generate concrete tasks from a recurrence template",
        "description": "Creates missing occurrence rows between `from` and `to` for a template (`is_template=true`). Idempotent per (`series_id`, `occurrence_date`).",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64", "minimum": 1 },
            "description": "Template task id"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/MaterializeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Generation result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/MaterializeResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    }
  },
  "components": {
    "responses": {
      "BadRequest": {
        "description": "Bad request",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/Error" }
          }
        }
      }
    },
    "schemas": {
      "RecurrenceRule": {
        "type": "object",
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["daily_interval", "monthly_day", "specific_dates", "day_parity"]
          },
          "every_n_days": {
            "type": "integer",
            "minimum": 1,
            "description": "daily_interval only: repeat every N calendar days starting from anchor_date."
          },
          "anchor_date": {
            "type": "string",
            "format": "date",
            "description": "daily_interval only: anchor day (YYYY-MM-DD, UTC)."
          },
          "day_of_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 30,
            "description": "monthly_day only: repeat on this calendar day each month when it exists."
          },
          "dates": {
            "type": "array",
            "items": { "type": "string", "format": "date" },
            "description": "specific_dates only: concrete dates (YYYY-MM-DD, UTC)."
          },
          "parity": {
            "type": "string",
            "enum": ["even", "odd"],
            "description": "day_parity only: repeat on even/odd calendar days of month (by day-of-month number)."
          }
        }
      },
      "CreateTaskRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Daily patient calls"
          },
          "description": {
            "type": "string",
            "example": "Call discharged patients"
          },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "new"
          },
          "recurrence": {
            "$ref": "#/components/schemas/RecurrenceRule"
          },
          "materialize_horizon_days": {
            "type": "integer",
            "minimum": 1,
            "description": "Only when recurrence is present: initially generate occurrences for N UTC days starting today (defaults to 30 server-side)."
          }
        }
      },
      "UpdateTaskRequest": {
        "type": "object",
        "required": ["title", "status"],
        "properties": {
          "title": {
            "type": "string",
            "example": "Prepare release"
          },
          "description": {
            "type": "string",
            "example": "Collect release notes and check migrations"
          },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "in_progress"
          },
          "recurrence": {
            "$ref": "#/components/schemas/RecurrenceRule",
            "description": "Only applies when updating a recurrence template (`is_template=true`)."
          }
        }
      },
      "MaterializeRequest": {
        "type": "object",
        "required": ["from", "to"],
        "properties": {
          "from": { "type": "string", "format": "date", "example": "2026-05-01" },
          "to": { "type": "string", "format": "date", "example": "2026-05-31" }
        }
      },
      "MaterializeResponse": {
        "type": "object",
        "required": ["created"],
        "properties": {
          "created": {
            "type": "integer",
            "minimum": 0,
            "description": "How many new occurrence rows were inserted."
          }
        }
      },
      "Task": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64", "example": 1 },
          "title": { "type": "string", "example": "Daily patient calls" },
          "description": {
            "type": "string",
            "example": "Call discharged patients"
          },
          "status": {
            "type": "string",
            "enum": ["new", "in_progress", "done"],
            "example": "new"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-24T12:34:56Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-03-24T12:34:56Z"
          },
          "series_id": {
            "type": "string",
            "format": "uuid",
            "description": "Stable id for all tasks in the same recurrence series."
          },
          "template_id": {
            "type": "integer",
            "format": "int64",
            "description": "Points to the recurrence template row when this row is a generated occurrence."
          },
          "occurrence_date": {
            "type": "string",
            "format": "date",
            "description": "UTC calendar day this occurrence represents (generated rows)."
          },
          "is_template": {
            "type": "boolean",
            "description": "True when this row stores recurrence settings and titles for the series."
          },
          "recurrence_kind": {
            "type": "string",
            "enum": ["daily_interval", "monthly_day", "specific_dates", "day_parity"],
            "description": "Stored on templates for quick filtering/display."
          },
          "recurrence": {
            "$ref": "#/components/schemas/RecurrenceRule",
            "description": "Stored only on templates."
          }
        }
      },
      "Error": {
        "type": "object",
        "properties": {
          "error": { "type": "string", "example": "task not found" }
        }
      }
    }
  }
}
